# Create a safe .env.example file for documentation
cat > .env.example << 'EOF'
# ============================================================
# EASYSUCCOR BOT - ENVIRONMENT CONFIGURATION EXAMPLE
# ============================================================
# Copy this file to .env and fill in your actual values
# ============================================================

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/easysuccor
NODE_ENV=development

# Security
ADMIN_API_KEY=your-admin-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here
SESSION_SECRET=your-session-secret-here

# Telegram Bot
BOT_TOKEN=your-bot-token-from-botfather
BOT_USERNAME=YourBotUsername

# Admin
ADMIN_CHAT_ID=your-telegram-chat-id
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE_1=099XXXXXXX
ADMIN_PHONE_2=088XXXXXXX

# Email
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Payment Methods
PAYMENT_AIRTEL=099XXXXXXX
PAYMENT_TNM=088XXXXXXX
PAYMENT_MO626=XXXXXXXXXX

# Pricing (examples - adjust as needed)
STUDENT_CV=6000
STUDENT_EDITABLE_CV=8000
PROFESSIONAL_CV=10000
PROFESSIONAL_EDITABLE_CV=12000

# Referral
REFERRAL_REWARD_LEVEL1=2000
REFERRAL_FRIEND_DISCOUNT=10

# Feature Flags
FEATURE_INSTALLMENTS=true
FEATURE_PAY_LATER=true
FEATURE_REFERRALS=true
FEATURE_DEEPSEEK_AI=true
EOF

echo "✅ .env file updated with all new features!"
echo "✅ .env.example created for documentation!"