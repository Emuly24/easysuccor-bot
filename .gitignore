# ============================================================
# ENVIRONMENT VARIABLES & CONFIG
# ============================================================
.env
.env.*
config.php
webhook.php           # <-- ONLY exclude if it contains live credentials
index.php             # <-- ONLY exclude if it contains live credentials

# ============================================================
# DEPENDENCIES (PHP Composer)
# ============================================================
vendor/

# ============================================================
# GENERATED & UPLOADED FILES (Server-side only)
# ============================================================
uploads/
exports/
temp/
logs/
data/
sessions/
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# ============================================================
# SENSITIVE BACKUPS & LOGS
# ============================================================
*.backup
*.bak
*.old
*~
*.log
error.log

# ============================================================
# OS & IDE
# ============================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*.lock

# ============================================================
# SSL CERTIFICATES
# ============================================================
*.pem
*.crt
*.key
*.csr

# ============================================================
# KEEP FOLDERS (but not files) – Optional
# ============================================================
!uploads/.gitkeep
!exports/.gitkeep
!temp/.gitkeep
!logs/.gitkeep
!data/.gitkeep